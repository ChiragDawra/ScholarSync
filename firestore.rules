rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    function isValidNumber(field, min, max) {
      return field is number && field >= min && field <= max;
    }

    // ── Block all access by default ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── User data — owner-only access ──
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false; // top-level doc not used directly

      // Profile
      match /profile/data {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid)
          && isValidString(request.resource.data.name, 100)
          && isValidString(request.resource.data.college, 200)
          && request.resource.data.uid == uid;
      }

      // Exams
      match /exams/{examId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.subjectId, 100)
          && request.resource.data.date is timestamp
          && isValidNumber(request.resource.data.difficulty, 1, 5);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Assignments
      match /assignments/{assignmentId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.title, 300)
          && request.resource.data.dueDate is timestamp
          && request.resource.data.status in ['todo', 'in_progress', 'done']
          && request.resource.data.complexity in ['easy', 'medium', 'high'];
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Sessions (Pomodoro data)
      match /sessions/{sessionId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidNumber(request.resource.data.durationMinutes, 0, 600)
          && isValidNumber(request.resource.data.focusScore, 0, 100);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Goals
      match /goals/{goalId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.title, 300)
          && request.resource.data.type in ['weekly', 'monthly'];
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Courses (GPA Predictor)
      match /courses/{courseId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.subjectId, 100)
          && isValidNumber(request.resource.data.currentScore, 0, 1000)
          && isValidNumber(request.resource.data.maxScore, 1, 1000)
          && isValidNumber(request.resource.data.creditHours, 1, 10);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Streak
      match /streak/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // Settings (GPA scale, notification prefs, etc.)
      match /settings/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // Chat messages (AI Coach)
      match /chat/{messageId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && isValidString(request.resource.data.content, 5000)
          && request.resource.data.role in ['user', 'assistant'];
        allow delete: if isOwner(uid);
      }
    }
  }
}
